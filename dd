-- ==========================================
-- FORTNITE-STYLE HIT MARKERS (BUBBLY/CARTOONY)
-- Fixed: Proper fade + Jiggle animation
-- ==========================================

local HitMarkerSystem = {}

HitMarkerSystem.hitMarkers = {}
HitMarkerSystem.hitMarkerIdCounter = 0

-- BUBBLY FONT (Fredoka One)
local BUBBLE_FONT = Font.fromId(12187360391)

HitMarkerSystem.OUTLINE_THICKNESS = 5
HitMarkerSystem.SHADOW_OFFSET = 4

function HitMarkerSystem.getRandomOffset()
    local angle = math.random() * math.pi * 2
    local distance = math.random(15, 60)
    local verticalOffset = math.random(-25, 35)
    return Vector2.new(
        math.cos(angle) * distance,
        math.sin(angle) * distance * 0.6 + verticalOffset
    )
end

function HitMarkerSystem.getRandomRotation()
    return math.random(-35, 35)
end

function HitMarkerSystem.createHitMarker(damageAmount, targetCharacter, hitPart, flags)
    HitMarkerSystem.hitMarkerIdCounter = HitMarkerSystem.hitMarkerIdCounter + 1
    local id = HitMarkerSystem.hitMarkerIdCounter
    
    if not flags.HitMarkersEnabled then return nil end
    
    -- Get target position
    local targetPos = nil
    local camera = workspace.CurrentCamera
    local viewport = camera.ViewportSize
    
    if targetCharacter and targetCharacter.Parent then
        local head = targetCharacter:FindFirstChild("Head")
        if head then
            targetPos = head.Position
        else
            local hrp = targetCharacter:FindFirstChild("HumanoidRootPart")
            if hrp then
                targetPos = hrp.Position
            end
        end
    end
    
    if not targetPos then return nil end
    
    -- Convert to screen position
    local screenPos, onScreen = camera:WorldToViewportPoint(targetPos)
    
    if not onScreen or screenPos.Z <= 0 then
        screenPos = Vector3.new(viewport.X / 2, viewport.Y / 2, 1)
    end
    
    local color = flags.HitMarkerColor and flags.HitMarkerColor.Color or Color3.fromRGB(255, 255, 255)
    local size = flags.HitMarkerSize or 58
    local duration = flags.HitMarkerDuration or 0.5
    local isHeadshot = hitPart and (hitPart.Name == "Head" or string.find(hitPart.Name, "Head"))
    
    local damageText = "+" .. math.floor(damageAmount)
    
    local finalSize = size
    if isHeadshot then
        finalSize = size + 16
    elseif damageAmount > 50 then
        finalSize = size + 12
    elseif damageAmount > 30 then
        finalSize = size + 6
    end
    
    local randomOffset = HitMarkerSystem.getRandomOffset()
    local randomRotation = HitMarkerSystem.getRandomRotation()
    
    -- JIGGLE SETTINGS
    local jiggleAmount = math.random(8, 18)  -- How much it shakes
    local jiggleSpeed = math.random(12, 25)  -- How fast it shakes
    
    -- MAIN TEXT
    local text = Drawing.new("Text")
    text.Text = damageText
    text.Size = finalSize * 1.3  -- Start bigger for pop effect
    text.Color = color
    text.Center = true
    text.Outline = true
    text.OutlineColor = Color3.fromRGB(0, 0, 0)
    text.OutlineThickness = HitMarkerSystem.OUTLINE_THICKNESS
    text.FontFace = BUBBLE_FONT
    text.Visible = true
    text.ZIndex = 10
    text.Rotation = randomRotation
    text.Transparency = 0  -- Fully visible
    text.Position = Vector2.new(screenPos.X + randomOffset.X, screenPos.Y + randomOffset.Y)
    
    -- SHADOW
    local shadow = Drawing.new("Text")
    shadow.Text = damageText
    shadow.Size = finalSize * 1.3
    shadow.Color = Color3.fromRGB(0, 0, 0)
    shadow.Center = true
    shadow.Outline = false
    shadow.FontFace = BUBBLE_FONT
    shadow.Visible = true
    shadow.Transparency = 0.5
    shadow.ZIndex = 9
    shadow.Rotation = randomRotation
    shadow.Position = Vector2.new(text.Position.X + HitMarkerSystem.SHADOW_OFFSET, text.Position.Y + HitMarkerSystem.SHADOW_OFFSET)
    
    local floatDirection = {
        x = math.random(-25, 25),
        y = math.random(-90, -60)
    }
    
    local marker = {
        id = id,
        text = text,
        shadow = shadow,
        startTime = tick(),
        duration = duration,
        startPos = text.Position,
        startSize = finalSize,
        startRotation = randomRotation,
        floatDirection = floatDirection,
        jiggleAmount = jiggleAmount,
        jiggleSpeed = jiggleSpeed,
        floatDistance = math.random(70, 110),
        isHeadshot = isHeadshot
    }
    
    HitMarkerSystem.hitMarkers[id] = marker
    return id
end

function HitMarkerSystem.updateHitMarkers()
    local now = tick()
    
    for id, marker in pairs(HitMarkerSystem.hitMarkers) do
        local elapsed = now - marker.startTime
        local t = math.clamp(elapsed / marker.duration, 0, 1)
        
        -- JIGGLE ANIMATION (only during first 20% of lifetime)
        local jiggleX = 0
        local jiggleY = 0
        if t < 0.2 then
            -- Fast jiggle that fades out
            local jiggleT = t / 0.2  -- 0 to 1 during jiggle phase
            local intensity = 1 - jiggleT  -- Fades out
            jiggleX = math.sin(elapsed * marker.jiggleSpeed) * marker.jiggleAmount * intensity
            jiggleY = math.cos(elapsed * marker.jiggleSpeed * 1.3) * (marker.jiggleAmount * 0.7) * intensity
        end
        
        -- POP effect (shrink from big to normal size)
        local sizeMultiplier = 1
        if t < 0.12 then
            -- Pop in: shrink from 1.3x to 1.0x
            local popT = t / 0.12
            sizeMultiplier = 1.3 - (popT * 0.3)
        elseif t > 0.7 then
            -- Shrink on fade out
            sizeMultiplier = 1 - ((t - 0.7) / 0.3) * 0.2
        end
        
        local newSize = marker.startSize * sizeMultiplier
        
        -- Float up animation
        local easeOut = 1 - (1 - t) ^ 1.2
        local floatX = marker.floatDirection.x * easeOut
        local floatY = marker.floatDirection.y * easeOut
        
        -- Final position
        local finalPos = Vector2.new(
            marker.startPos.X + jiggleX + floatX,
            marker.startPos.Y + jiggleY - marker.floatDistance * easeOut + floatY * 0.3
        )
        
        -- Rotation (slowly straightens)
        local currentRotation = marker.startRotation * (1 - t * 0.6)
        
        -- FADE OUT (starts at 35%, completely gone by 100%)
        local alpha = 1
        if t > 0.35 then
            alpha = 1 - ((t - 0.35) / 0.65)
            alpha = math.clamp(alpha, 0, 1)
        end
        
        pcall(function()
            if marker.text then
                marker.text.Position = finalPos
                marker.text.Size = newSize
                marker.text.Transparency = 1 - alpha
                marker.text.Rotation = currentRotation
            end
            if marker.shadow then
                marker.shadow.Position = Vector2.new(finalPos.X + HitMarkerSystem.SHADOW_OFFSET, finalPos.Y + HitMarkerSystem.SHADOW_OFFSET)
                marker.shadow.Size = newSize
                marker.shadow.Transparency = 0.5 * (1 - alpha)
                marker.shadow.Rotation = currentRotation
            end
        end)
        
        -- Remove when done
        if elapsed >= marker.duration then
            pcall(function()
                if marker.text then marker.text:Remove() end
                if marker.shadow then marker.shadow:Remove() end
            end)
            HitMarkerSystem.hitMarkers[id] = nil
        end
    end
end

function HitMarkerSystem.clearAll()
    for id, marker in pairs(HitMarkerSystem.hitMarkers) do
        pcall(function()
            if marker.text then marker.text:Remove() end
            if marker.shadow then marker.shadow:Remove() end
        end)
        HitMarkerSystem.hitMarkers[id] = nil
    end
end

function HitMarkerSystem.show(damage, targetCharacter, hitPart, flags)
    if not flags.HitMarkersEnabled then return end
    if not targetCharacter or not targetCharacter.Parent then return end
    
    local isHeadshot = hitPart and (hitPart.Name == "Head" or string.find(hitPart.Name, "Head"))
    
    if isHeadshot and flags.HitMarkerHeadshotColor then
        local headshotColor = flags.HitMarkerHeadshotColor.Color or Color3.fromRGB(255, 200, 50)
        local oldColor = flags.HitMarkerColor
        flags.HitMarkerColor = {Color = headshotColor, Transparency = 1}
        HitMarkerSystem.createHitMarker(damage, targetCharacter, hitPart, flags)
        flags.HitMarkerColor = oldColor
    else
        HitMarkerSystem.createHitMarker(damage, targetCharacter, hitPart, flags)
    end
end

-- Start update loop
task.spawn(function()
    while true do
        HitMarkerSystem.updateHitMarkers()
        task.wait()
    end
end)

-- Make globally accessible
_G.HitMarkerSystem = HitMarkerSystem
_G.clearAllHitMarkers = HitMarkerSystem.clearAll
_G.showHitMarker = HitMarkerSystem.show

print("Hit Marker System Loaded! (Jiggle + Pop + Fade)")
