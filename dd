-- ==========================================
-- FORTNITE-STYLE HIT MARKERS (Cartoon/Bold)
-- Random positions around head + Tilted/Sideways
-- ==========================================

local HitMarkerSystem = {}

HitMarkerSystem.hitMarkers = {}
HitMarkerSystem.hitMarkerIdCounter = 0
HitMarkerSystem.FORTNITE_OUTLINE_THICKNESS = 4
HitMarkerSystem.FORTNITE_SHADOW_OFFSET = 3

-- Get RANDOM position around the head (360 degrees, various distances)
function HitMarkerSystem.getRandomOffset()
    -- Random angle (0 to 360 degrees) for full circle around head
    local angle = math.random() * math.pi * 2
    -- Random distance from head (closer or further)
    local distance = math.random(20, 70)
    -- Random vertical offset (higher or lower on head)
    local verticalOffset = math.random(-30, 40)
    
    return Vector2.new(
        math.cos(angle) * distance,  -- X: left/right
        math.sin(angle) * distance * 0.7 + verticalOffset  -- Y: up/down with less vertical spread
    )
end

-- Get RANDOM rotation (tilted sideways)
function HitMarkerSystem.getRandomRotation()
    -- Random tilt between -45 and 45 degrees
    -- Negative = tilted left, Positive = tilted right
    return math.random(-45, 45)
end

-- Create hit marker
function HitMarkerSystem.createHitMarker(damageAmount, targetCharacter, hitPart, flags)
    HitMarkerSystem.hitMarkerIdCounter = HitMarkerSystem.hitMarkerIdCounter + 1
    local id = HitMarkerSystem.hitMarkerIdCounter
    
    if not flags.HitMarkersEnabled then return nil end
    
    local color = flags.HitMarkerColor and flags.HitMarkerColor.Color or Color3.fromRGB(255, 255, 255)
    local size = flags.HitMarkerSize or 52
    local duration = flags.HitMarkerDuration or 0.4
    local isHeadshot = hitPart and (hitPart.Name == "Head" or string.find(hitPart.Name, "Head"))
    
    local damageText = "+" .. math.floor(damageAmount)
    
    -- Size based on damage
    local finalSize = size
    if isHeadshot then
        finalSize = size + 12
    elseif damageAmount > 50 then
        finalSize = size + 8
    elseif damageAmount > 30 then
        finalSize = size + 4
    end
    
    -- RANDOM POSITION AROUND HEAD (different per hit)
    local randomOffset = HitMarkerSystem.getRandomOffset()
    
    -- RANDOM ROTATION (tilted sideways)
    local randomRotation = HitMarkerSystem.getRandomRotation()
    
    -- RANDOM FLOAT DIRECTION (some go up-left, some up-right, some straight up)
    local floatDirection = {
        x = math.random(-15, 15),  -- Random horizontal drift
        y = math.random(-80, -50)  -- Always up but random amount
    }
    
    -- MAIN TEXT (tilted/rotated)
    local text = Drawing.new("Text")
    text.Text = damageText
    text.Size = finalSize
    text.Color = color
    text.Center = true
    text.Outline = true
    text.OutlineColor = Color3.fromRGB(0, 0, 0)
    text.OutlineThickness = HitMarkerSystem.FORTNITE_OUTLINE_THICKNESS
    text.Font = Drawing.Fonts.Monospace
    text.Visible = true
    text.ZIndex = 10
    text.Rotation = randomRotation  -- APPLY RANDOM TILT
    
    -- GLOW (same rotation)
    local glow = Drawing.new("Text")
    glow.Text = damageText
    glow.Size = finalSize + 6
    glow.Color = Color3.fromRGB(0, 0, 0)
    glow.Center = true
    glow.Outline = false
    glow.Font = Drawing.Fonts.Monospace
    glow.Visible = true
    glow.Transparency = 0.6
    glow.ZIndex = 8
    glow.Rotation = randomRotation
    
    -- SHADOW (same rotation)
    local shadow = Drawing.new("Text")
    shadow.Text = damageText
    shadow.Size = finalSize
    shadow.Color = Color3.fromRGB(0, 0, 0)
    shadow.Center = true
    shadow.Outline = false
    shadow.Font = Drawing.Fonts.Monospace
    shadow.Visible = true
    shadow.Transparency = 0.4
    shadow.ZIndex = 9
    shadow.Rotation = randomRotation
    
    local marker = {
        id = id,
        text = text,
        glow = glow,
        shadow = shadow,
        startTime = tick(),
        duration = duration,
        targetChar = targetCharacter,
        targetPart = hitPart or (targetCharacter and targetCharacter:FindFirstChild("Head")),
        startSize = finalSize,
        startOffset = randomOffset,
        startRotation = randomRotation,
        floatDirection = floatDirection,
        wiggleAmount = math.random(5, 15),
        floatDistance = math.random(60, 100),
        initialScreenPos = nil,
        isHeadshot = isHeadshot
    }
    
    HitMarkerSystem.hitMarkers[id] = marker
    return id
end

-- Update hit markers
function HitMarkerSystem.updateHitMarkers()
    local now = tick()
    local camera = workspace.CurrentCamera
    local viewport = camera.ViewportSize
    
    for id, marker in pairs(HitMarkerSystem.hitMarkers) do
        local elapsed = now - marker.startTime
        local t = math.clamp(elapsed / marker.duration, 0, 1)
        
        -- Check if target still exists
        local targetPos = nil
        local targetExists = false
        
        if marker.targetChar and marker.targetChar.Parent then
            local head = marker.targetChar:FindFirstChild("Head")
            if head and head:IsA("BasePart") then
                targetPos = head.Position
                targetExists = true
            else
                local hrp = marker.targetChar:FindFirstChild("HumanoidRootPart")
                if hrp then
                    targetPos = hrp.Position
                    targetExists = true
                end
            end
        end
        
        -- Calculate screen position
        local screenPos = Vector2.new(viewport.X / 2, viewport.Y / 2)
        local onScreen = false
        
        if targetExists and targetPos then
            local pos, onScrn = camera:WorldToViewportPoint(targetPos)
            if onScrn and pos.Z > 0 then
                screenPos = Vector2.new(pos.X, pos.Y)
                onScreen = true
            end
        end
        
        if onScreen and not marker.initialScreenPos then
            marker.initialScreenPos = screenPos
        elseif not onScreen and marker.initialScreenPos then
            screenPos = marker.initialScreenPos
            t = math.min(t * 1.5, 1)
        end
        
        -- Apply random offset (different position per hit)
        local offset = marker.startOffset
        
        -- Float in random direction (not just straight up)
        local easeOut = 1 - (1 - t) ^ 1.3
        local floatX = marker.floatDirection.x * easeOut
        local floatY = marker.floatDirection.y * easeOut
        
        -- Bounce effect at start
        local bounce = 0
        if t < 0.2 then
            bounce = math.sin(t * math.pi * 3) * (1 - t) * 15
        end
        
        -- Wiggle effect
        local wiggle = math.sin(t * math.pi * 6) * (1 - t) * marker.wiggleAmount
        
        -- Final position (floats in random direction)
        local finalPos = Vector2.new(
            screenPos.X + offset.X + wiggle + bounce + floatX,
            screenPos.Y + offset.Y - marker.floatDistance * easeOut + floatY * 0.5
        )
        
        -- Size animation: POP IN then shrink
        local sizeMultiplier = 1
        if t < 0.12 then
            sizeMultiplier = 1 + (0.7 * (1 - t / 0.12))
        elseif t > 0.7 then
            sizeMultiplier = 1 - ((t - 0.7) / 0.3) * 0.2
        end
        
        local newSize = marker.startSize * sizeMultiplier
        
        -- Rotation animation (un-rotate slightly as it fades)
        local currentRotation = marker.startRotation * (1 - t * 0.5)
        
        -- Fade out
        local alpha = 1
        if t > 0.5 then
            alpha = 1 - ((t - 0.5) / 0.5)
            alpha = math.clamp(alpha, 0, 1)
        end
        
        pcall(function()
            if marker.text then
                marker.text.Position = finalPos
                marker.text.Size = newSize
                marker.text.Transparency = 1 - alpha
                marker.text.Rotation = currentRotation
            end
            if marker.glow then
                marker.glow.Position = Vector2.new(finalPos.X, finalPos.Y)
                marker.glow.Size = newSize + 6
                marker.glow.Transparency = 0.6 * (1 - alpha * 0.5)
                marker.glow.Rotation = currentRotation
            end
            if marker.shadow then
                marker.shadow.Position = Vector2.new(finalPos.X + HitMarkerSystem.FORTNITE_SHADOW_OFFSET, finalPos.Y + HitMarkerSystem.FORTNITE_SHADOW_OFFSET)
                marker.shadow.Size = newSize
                marker.shadow.Transparency = 0.4 * (1 - alpha)
                marker.shadow.Rotation = currentRotation
            end
        end)
        
        if elapsed >= marker.duration then
            pcall(function()
                if marker.text then marker.text:Remove() end
                if marker.glow then marker.glow:Remove() end
                if marker.shadow then marker.shadow:Remove() end
            end)
            HitMarkerSystem.hitMarkers[id] = nil
        end
    end
end

function HitMarkerSystem.clearAll()
    for id, marker in pairs(HitMarkerSystem.hitMarkers) do
        pcall(function()
            if marker.text then marker.text:Remove() end
            if marker.glow then marker.glow:Remove() end
            if marker.shadow then marker.shadow:Remove() end
        end)
        HitMarkerSystem.hitMarkers[id] = nil
    end
end

function HitMarkerSystem.show(damage, targetCharacter, hitPart, flags)
    if not flags.HitMarkersEnabled then return end
    if not targetCharacter or not targetCharacter.Parent then return end
    
    local isHeadshot = hitPart and (hitPart.Name == "Head" or string.find(hitPart.Name, "Head"))
    
    if isHeadshot and flags.HitMarkerHeadshotColor then
        local headshotColor = flags.HitMarkerHeadshotColor.Color or Color3.fromRGB(255, 200, 50)
        local oldColor = flags.HitMarkerColor
        flags.HitMarkerColor = {Color = headshotColor, Transparency = 1}
        HitMarkerSystem.createHitMarker(damage, targetCharacter, hitPart, flags)
        flags.HitMarkerColor = oldColor
    else
        HitMarkerSystem.createHitMarker(damage, targetCharacter, hitPart, flags)
    end
end

-- Start update loop
task.spawn(function()
    while true do
        HitMarkerSystem.updateHitMarkers()
        task.wait()
    end
end)

-- Make globally accessible
_G.HitMarkerSystem = HitMarkerSystem
_G.clearAllHitMarkers = HitMarkerSystem.clearAll
_G.showHitMarker = HitMarkerSystem.show

print("Hit Marker System Loaded! (Random positions + Tilted rotation)")
