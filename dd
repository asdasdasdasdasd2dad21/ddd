-- ==========================================
-- ZERO DELAY HIT MARKERS (INSTANT)
-- No animations, just appears and fades
-- ==========================================

local HitMarkerSystem = {}
HitMarkerSystem.hitMarkers = {}
HitMarkerSystem.hitMarkerIdCounter = 0

function HitMarkerSystem.show(damage, targetCharacter, hitPart, flags)
    if not flags.HitMarkersEnabled then return end
    if not targetCharacter or not targetCharacter.Parent then return end
    
    -- Get head position IMMEDIATELY
    local head = targetCharacter:FindFirstChild("Head")
    if not head then return end
    
    local camera = workspace.CurrentCamera
    local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
    if not onScreen or screenPos.Z <= 0 then return end
    
    -- Settings
    local color = flags.HitMarkerColor and flags.HitMarkerColor.Color or Color3.fromRGB(255, 255, 255)
    local size = flags.HitMarkerSize or 55
    local duration = flags.HitMarkerDuration or 0.35
    local isHeadshot = hitPart and hitPart.Name == "Head"
    
    -- Random offset around head
    local offsetX = math.random(-40, 40)
    local offsetY = math.random(-30, 30)
    
    -- Create text INSTANTLY
    local text = Drawing.new("Text")
    text.Text = "+" .. math.floor(damage)
    text.Size = isHeadshot and size + 10 or size
    text.Color = isHeadshot and Color3.fromRGB(255, 200, 50) or color
    text.Center = true
    text.Outline = true
    text.OutlineColor = Color3.fromRGB(0, 0, 0)
    text.OutlineThickness = 4
    text.Font = Drawing.Fonts.UI
    text.Visible = true
    text.Position = Vector2.new(screenPos.X + offsetX, screenPos.Y + offsetY)
    
    -- Shadow
    local shadow = Drawing.new("Text")
    shadow.Text = text.Text
    shadow.Size = text.Size
    shadow.Color = Color3.fromRGB(0, 0, 0)
    shadow.Center = true
    shadow.Outline = false
    shadow.Font = Drawing.Fonts.UI
    shadow.Visible = true
    shadow.Transparency = 0.5
    shadow.Position = Vector2.new(text.Position.X + 3, text.Position.Y + 3)
    
    local id = HitMarkerSystem.hitMarkerIdCounter + 1
    HitMarkerSystem.hitMarkerIdCounter = id
    local startTime = tick()
    
    HitMarkerSystem.hitMarkers[id] = {
        text = text,
        shadow = shadow,
        startTime = startTime,
        duration = duration,
        startX = text.Position.X,
        startY = text.Position.Y
    }
end

-- Simple update loop
task.spawn(function()
    while true do
        local now = tick()
        for id, marker in pairs(HitMarkerSystem.hitMarkers) do
            local elapsed = now - marker.startTime
            local t = elapsed / marker.duration
            
            if t >= 1 then
                pcall(function()
                    if marker.text then marker.text:Remove() end
                    if marker.shadow then marker.shadow:Remove() end
                end)
                HitMarkerSystem.hitMarkers[id] = nil
            else
                -- Simple fade
                local alpha = 1 - t
                pcall(function()
                    if marker.text then
                        marker.text.Transparency = 1 - alpha
                        marker.text.Position = Vector2.new(marker.startX, marker.startY - (t * 40))
                    end
                    if marker.shadow then
                        marker.shadow.Transparency = 0.5 * (1 - alpha)
                        marker.shadow.Position = Vector2.new(marker.startX + 3, marker.startY + 3 - (t * 40))
                    end
                end)
            end
        end
        task.wait()
    end
end)

function HitMarkerSystem.clearAll()
    for id, marker in pairs(HitMarkerSystem.hitMarkers) do
        pcall(function()
            if marker.text then marker.text:Remove() end
            if marker.shadow then marker.shadow:Remove() end
        end)
        HitMarkerSystem.hitMarkers[id] = nil
    end
end

_G.HitMarkerSystem = HitMarkerSystem
_G.clearAllHitMarkers = HitMarkerSystem.clearAll
_G.showHitMarker = HitMarkerSystem.show

print("ZERO DELAY Hit Marker System Loaded!")
